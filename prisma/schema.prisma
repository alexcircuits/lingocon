// LingoCon Prisma schema — PostgreSQL
//
// Domain overview (see docs/DATABASE.md for prose explanations):
// - Auth.js tables: User, Account, Session, VerificationToken
// - Core content: Language (+ collaborators, visibility), ScriptSymbol, GrammarPage, DictionaryEntry,
//   Paradigm, ExampleSentence, Article, Text, Comment, Activity, …
// - Families / reconstruction: LanguageFamily, ProtoWord
// - Admin: AuditLog, moderation fields on User
//
// After editing: `npm run db:migrate` (and commit the new migration directory).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean   @default(false)
  
  // Admin moderation fields
  isSuspended   Boolean   @default(false)
  suspendedAt   DateTime?
  suspendReason String?   @db.Text
  adminNotes    String?   @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  languages Language[]
  families  LanguageFamily[]
  collaborations LanguageCollaborator[]
  activities Activity[]
  favorites Favorite[]
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")
  articles  Article[]
  texts     Text[]
  auditLogs AuditLog[]
  userBadges UserBadge[]
  comments   Comment[]
  modules        Module[]
  moduleInstalls ModuleInstall[]
  moduleReviews  ModuleReview[]
  moduleReports  ModuleReport[]
  extensionTokens ExtensionToken[]
  enrollments       Enrollment[]
  xpEvents          XPEvent[]
  courses           Course[]
  lessonCompletions LessonCompletion[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type             String
  provider         String
  providerAccountId String
  refresh_token    String? @db.Text
  access_token     String? @db.Text
  expires_at       Int?
  token_type       String?
  scope            String?
  id_token         String? @db.Text
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Domain models
model Language {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  flagUrl     String?  // URL to flag image
  visibility  Visibility @default(PRIVATE)
  category    LanguageCategory @default(CONLANG)
  metadata    Json?    // Typology and wizard data (wordOrder, morphologicalTendency, etc.)
  
  // Social & Community Links
  discordUrl  String?
  telegramUrl String?
  websiteUrl  String?

  // Custom Font for Script
  fontUrl     String?  // Path to uploaded font file
  fontFamily  String?  // CSS font-family name
  fontScale   Float    @default(1.0)
  
  // Diacritics support - when enabled, allows diacritical variants of base letters
  allowsDiacritics Boolean @default(false)

  // Whether other users can fork/evolve this language
  allowForking Boolean @default(false)

  // Lesson grading: accept romanized (Latin transliteration) answers as correct.
  // Default off — for many conlangs the romanization is lossy or ambiguous, so
  // owners must opt in per language.
  acceptRomanizedAnswers Boolean @default(false)

  // Language Family Tree
  parentLanguageId String?
  parentLanguage   Language?  @relation("LanguageFamily", fields: [parentLanguageId], references: [id], onDelete: SetNull)
  childLanguages   Language[] @relation("LanguageFamily")
  externalAncestry String?    // Legacy: free-text ancestry label (kept for backward compat)

  // Language Family (proper model)
  familyId    String?
  family      LanguageFamily? @relation(fields: [familyId], references: [id], onDelete: SetNull)

  ownerId           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastSlugChangedAt DateTime? // Tracks when slug was last renamed

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  scriptSymbols   ScriptSymbol[]
  grammarPages    GrammarPage[]
  dictionaryEntries DictionaryEntry[]
  paradigms       Paradigm[]
  collaborators   LanguageCollaborator[]
  activities      Activity[]
  favorites       Favorite[]
  articles        Article[]
  texts           Text[]
  comments        Comment[]
  slugReservations SlugReservation[]
  moduleInstalls  ModuleInstall[]
  enrollments     Enrollment[]
  courses         Course[]
  uiTranslations  ConlangTranslation[]

  @@index([ownerId])
  @@index([slug])
  @@index([parentLanguageId])
  @@index([familyId])
  @@index([category])
  @@map("languages")
}

// Broad categorization of a language by origin/use.
// CONLANG covers user-created constructed languages (default).
// NATURAL covers documented natural languages.
// ENDANGERED, RESTORED, HISTORICAL describe natural-language status.
// FICTIONAL covers conlangs designed for fiction (Quenya, Klingon...).
// AUXILIARY covers international auxiliary languages (Esperanto...).
enum LanguageCategory {
  CONLANG
  NATURAL
  ENDANGERED
  RESTORED
  HISTORICAL
  FICTIONAL
  AUXILIARY
  OTHER
}

// Reserves an old slug for 180 days after a language renames itself.
// Prevents recycling attacks and enables temporary SEO-safe redirects.
model SlugReservation {
  id            String   @id @default(cuid())
  slug          String   @unique          // the old slug being held
  languageId    String                    // language that previously owned it
  reservedUntil DateTime                  // expiry: createdAt + 180 days
  createdAt     DateTime @default(now())

  language      Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([reservedUntil])
  @@map("slug_reservations")
}

enum Visibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum FamilyType {
  SYSTEM
  USER
}

model LanguageFamily {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  visibility  Visibility @default(PRIVATE)
  type        FamilyType @default(USER)
  ownerId     String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Hierarchical family tree
  parentFamilyId String?
  parentFamily   LanguageFamily?  @relation("FamilyHierarchy", fields: [parentFamilyId], references: [id], onDelete: SetNull)
  childFamilies  LanguageFamily[] @relation("FamilyHierarchy")

  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  languages   Language[]

  // Shared proto-vocabulary for this family node
  protoWords  ProtoWord[]

  @@index([parentFamilyId])
  @@index([ownerId])
  @@index([slug])
  @@index([type])
  @@map("language_families")
}

model ProtoWord {
  id          String   @id @default(cuid())
  lemma       String   // e.g. "*wódr̥" (water)
  gloss       String   // "water"
  ipa         String?
  notes       String?  @db.Text
  familyId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family      LanguageFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  derivations DictionaryEntry[] @relation("ProtoDerivation")

  @@index([familyId])
  @@index([familyId, lemma])
  @@map("proto_words")
}

enum CollaboratorRole {
  OWNER
  EDITOR
  VIEWER
}

model ScriptSymbol {
  id          String   @id @default(cuid())
  symbol      String   // Lowercase/normal form
  capitalSymbol String? // Uppercase/capital form (optional)
  ipa         String?  // International Phonetic Alphabet
  latin       String?  // Latin transliteration equivalent
  name        String?  // Optional name/description
  order       Int      @default(0)
  languageId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([languageId])
  @@index([languageId, order])
  @@map("script_symbols")
}

model GrammarPage {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     Json     // Rich text content (TipTap/BlockNote JSON)
  imageUrl    String?  // URL to cover/feature image
  order       Int      @default(0)
  paradigmId String?  // Optional link to paradigm table
  languageId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  paradigm    Paradigm? @relation(fields: [paradigmId], references: [id], onDelete: SetNull)
  lessonItems LessonItem[]

  @@unique([languageId, slug])
  @@index([languageId])
  @@index([languageId, order])
  @@index([paradigmId])
  @@map("grammar_pages")
}

model DictionaryEntry {
  id          String   @id @default(cuid())
  lemma       String   // Dictionary form / headword
  gloss       String   // Translation/definition
  ipa         String?  // Pronunciation
  audioUrl    String?  // URL to user-recorded pronunciation audio
  partOfSpeech String? // e.g., "noun", "verb", "adj"
  etymology   String?  @db.Text // Word origin/etymology
  relatedWords Json?   // Array of related word IDs: ["id1", "id2"]
  notes       String?  @db.Text
  tags        Json?    // Array of tag strings: ["body", "food", "kinship"]
  paradigmId  String?  // Optional link to paradigm table
  languageId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Cognate tracking — traces word lineage across evolved languages
  sourceEntryId String?  // The ancestor word this entry evolved from
  sourceEntry   DictionaryEntry?  @relation("CognateChain", fields: [sourceEntryId], references: [id], onDelete: SetNull)
  derivedEntries DictionaryEntry[] @relation("CognateChain")

  // Link to proto-language vocabulary
  protoSourceId String?
  protoSource   ProtoWord? @relation("ProtoDerivation", fields: [protoSourceId], references: [id], onDelete: SetNull)

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  paradigm Paradigm? @relation(fields: [paradigmId], references: [id], onDelete: SetNull)
  exampleSentences ExampleSentence[]
  lessonItems      LessonItem[]

  @@index([languageId])
  @@index([languageId, lemma])
  @@index([paradigmId])
  @@index([sourceEntryId])
  @@index([protoSourceId])
  @@map("dictionary_entries")
}

model ExampleSentence {
  id                String   @id @default(cuid())
  sentence          String   // Sentence in the conlang
  gloss             String?  // Word-by-word gloss
  translation       String   // Free translation
  order             Int      @default(0)
  dictionaryEntryId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  entry       DictionaryEntry @relation(fields: [dictionaryEntryId], references: [id], onDelete: Cascade)
  lessonItems LessonItem[]

  @@index([dictionaryEntryId])
  @@map("example_sentences")
}

model Paradigm {
  id          String   @id @default(cuid())
  name        String   // e.g., "First Declension", "Present Tense"
  slots       Json     // Table structure: { rows: [...], columns: [...] }
  notes       String?  @db.Text
  languageId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  dictionaryEntries DictionaryEntry[]
  grammarPages GrammarPage[]
  articles Article[]
  texts Text[]

  @@index([languageId])
  @@map("paradigms")
}

model LanguageCollaborator {
  id          String           @id @default(cuid())
  languageId  String
  userId      String
  role        CollaboratorRole @default(VIEWER)
  permissions String[]         @default([])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([languageId, userId])
  @@index([languageId])
  @@index([userId])
  @@map("language_collaborators")
}

enum ActivityType {
  CREATED
  UPDATED
  DELETED
}

enum ActivityEntityType {
  LANGUAGE
  SCRIPT_SYMBOL
  GRAMMAR_PAGE
  DICTIONARY_ENTRY
  PARADIGM
  COLLABORATOR
  ARTICLE
  TEXT
  COMMENT
}

// Articles/News for a language
model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String
  excerpt     String?  @db.Text // Short summary
  content     Json     // Rich text content (TipTap/BlockNote JSON)
  coverImage  String?  // URL to cover image
  published   Boolean  @default(false)
  paradigmId String?  // Optional link to paradigm table
  languageId  String
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  paradigm Paradigm? @relation(fields: [paradigmId], references: [id], onDelete: SetNull)

  @@unique([languageId, slug])
  @@index([languageId])
  @@index([authorId])
  @@index([languageId, published])
  @@index([publishedAt])
  @@index([paradigmId])
  @@map("articles")
}

enum TextType {
  BOOK
  SHORT_STORY
  POEM
  SONG
  DIALOGUE
  ESSAY
  TRANSLATION
  OTHER
}

// Books and other texts in a language
model Text {
  id          String   @id @default(cuid())
  title       String
  slug        String
  description String?  @db.Text
  type        TextType @default(OTHER)
  content     Json?    // Rich text content for inline texts
  fileUrl     String?  // URL to uploaded file (PDF, etc.)
  fileName    String?  // Original file name
  fileSize    Int?     // File size in bytes
  coverImage  String?  // URL to cover image
  published   Boolean  @default(false)
  paradigmId String?  // Optional link to paradigm table
  languageId  String
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  paradigm    Paradigm? @relation(fields: [paradigmId], references: [id], onDelete: SetNull)
  lessonItems LessonItem[]

  @@unique([languageId, slug])
  @@index([languageId])
  @@index([authorId])
  @@index([languageId, type])
  @@index([paradigmId])
  @@map("texts")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "SUSPEND_USER", "UNPUBLISH_ARTICLE"
  resource    String   // e.g. "USER", "ARTICLE", "LANGUAGE"
  resourceId  String?
  details     Json?    // Additional info about the action
  adminId     String
  
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model Activity {
  id          String            @id @default(cuid())
  type        ActivityType
  entityType  ActivityEntityType
  entityId    String
  languageId  String
  userId      String
  description String?           @db.Text
  metadata    Json?             // Additional context (e.g., field changes)
  createdAt   DateTime          @default(now())

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([languageId])
  @@index([userId])
  @@index([languageId, createdAt])
  @@index([createdAt])
  @@map("activities")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  languageId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([userId, languageId])
  @@index([userId])
  @@index([languageId])
  @@map("favorites")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   // User who follows
  followingId String   // User being followed
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model PlatformUpdate {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  icon        String?  // Lucide icon name
  link        String?  // Optional link to more info
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("platform_updates")
}

// Badges and Achievements
enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum BadgeCategory {
  LANGUAGES     // Creating and publishing languages
  DICTIONARY    // Dictionary entries
  GRAMMAR       // Grammar pages
  SCRIPT        // Alphabet/script symbols
  SOCIAL        // Followers, favorites
  CONTENT       // Articles, texts
  ENGAGEMENT    // Streaks, consistency
}

model Badge {
  id          String        @id @default(cuid())
  key         String        @unique  // e.g., "first_language", "dictionary_100"
  name        String                 // Display name
  description String        @db.Text // How to earn it
  icon        String                 // Lucide icon name or emoji
  tier        BadgeTier     @default(BRONZE)
  category    BadgeCategory
  threshold   Int           @default(1)  // Number required to earn
  createdAt   DateTime      @default(now())

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badgeId   String
  progress  Int       @default(0)  // Current progress toward threshold
  earnedAt  DateTime?              // Null if not yet earned
  notified  Boolean   @default(false) // Whether the user has been notified
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

// Comments on public languages
model Comment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  languageId  String
  userId      String
  parentId    String?  // For threaded replies
  isHidden    Boolean  @default(false) // For moderation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([languageId])
  @@index([userId])
  @@index([parentId])
  @@index([languageId, createdAt])
  @@map("comments")
}

// Anonymous Surveys
enum QuestionType {
  TEXT
  SELECT
  MULTI_SELECT
}

model Survey {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions  SurveyQuestion[]
  responses  SurveyResponse[]

  @@index([slug])
  @@index([isActive])
  @@map("surveys")
}

model SurveyQuestion {
  id        String       @id @default(cuid())
  text      String
  type      QuestionType @default(TEXT)
  options   Json?        // Array of options for SELECT/MULTI_SELECT
  required  Boolean      @default(false)
  order     Int          @default(0)
  surveyId  String
  createdAt DateTime     @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@index([surveyId, order])
  @@map("survey_questions")
}

model SurveyResponse {
  id        String   @id @default(cuid())
  surveyId  String
  answers   Json     // { questionId: answer }
  createdAt DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@index([surveyId, createdAt])
  @@map("survey_responses")
}

// ───────────────────────────────────────────────────────────────────────────
// Modules — community-authored, hosted add-ons (see docs/MODULES_MARKETPLACE.md)
// ───────────────────────────────────────────────────────────────────────────

enum ModuleType {
  STUDIO_PANEL
  READER_WIDGET
  CONTENT_BLOCK
  TRANSFORMER
  GENERATOR
  EXPORTER
  IMPORTER
  VISUALIZER
  VALIDATOR
  THEME
}

// Distribution/execution tier. Tier 0 is pure declarative data (no code);
// Tier 1 is sandboxed client code; Tier 2 (reserved) is server/WASM.
enum ModuleTier {
  DECLARATIVE
  CLIENT_SANDBOX
  SERVER
}

enum ModuleStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  SUSPENDED
  DEPRECATED
}

enum ModuleReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

model Module {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  summary     String?      @db.Text  // Short one-liner for cards
  description String?      @db.Text  // Long README-style markdown
  type        ModuleType
  tier        ModuleTier   @default(DECLARATIVE)
  status      ModuleStatus @default(DRAFT)

  icon        String?      // Lucide icon name or emoji
  repoUrl     String?      // Source repository (trust signal)
  homepageUrl String?
  license     String?      // OSI license identifier, e.g. "MIT"
  tags        Json?        // Array of tag strings

  isOfficial       Boolean @default(false)
  isVerifiedAuthor Boolean @default(false)

  // Denormalized counters for cheap sort/display
  addCount    Int @default(0)   // number of active installs
  ratingSum   Int @default(0)   // sum of review ratings
  ratingCount Int @default(0)   // number of reviews
  ratingAverage Float @default(0) // average review rating

  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions  ModuleVersion[]
  installs  ModuleInstall[]
  reviews   ModuleReview[]
  reports   ModuleReport[]

  @@index([authorId])
  @@index([slug])
  @@index([status])
  @@index([type])
  @@index([status, type])
  @@map("modules")
}

model ModuleVersion {
  id          String   @id @default(cuid())
  moduleId    String
  version     String   // semver, e.g. "1.2.0"
  manifest    Json     // Parsed module.json
  permissions Json?    // Declared capability strings
  sdkRange    String?  // Compatible SDK semver range
  changelog   String?  @db.Text

  // Tier 0 declarative payload (rules/theme/word list). Null for code modules.
  data        Json?

  // Tier 1+ hosted bundle. Null for declarative modules.
  bundleUrl   String?
  bundleHash  String?
  // Inline sandboxed widget source (JS) for client-sandbox modules.
  bundleCode  String?  @db.Text

  yanked      Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  module   Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  installs ModuleInstall[]

  @@unique([moduleId, version])
  @@index([moduleId])
  @@index([moduleId, publishedAt])
  @@map("module_versions")
}

// One add of a module by a user. languageId set => scoped to that language;
// languageId null => account-wide (applies to all of the user's languages).
model ModuleInstall {
  id                 String   @id @default(cuid())
  moduleId           String
  versionId          String
  userId             String
  languageId         String?
  settings           Json?    // User-configured options validated against settingsSchema
  grantedPermissions Json?    // Capabilities the user consented to at add time
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  module   Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  version  ModuleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language?     @relation(fields: [languageId], references: [id], onDelete: Cascade)

  // Postgres treats NULLs as distinct, so an account-wide row and per-language
  // rows for the same module/user can coexist.
  @@unique([moduleId, userId, languageId])
  @@index([moduleId])
  @@index([userId])
  @@index([languageId])
  @@index([languageId, enabled])
  @@map("module_installs")
}

model ModuleReview {
  id        String   @id @default(cuid())
  moduleId  String
  userId    String
  rating    Int      // 1–5
  body      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([moduleId, userId])
  @@index([moduleId])
  @@index([userId])
  @@map("module_reviews")
}

model ModuleReport {
  id         String             @id @default(cuid())
  moduleId   String
  reporterId String
  reason     String             @db.Text
  status     ModuleReportStatus @default(OPEN)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([reporterId])
  @@index([status])
  @@map("module_reports")
}

// Browser extension API tokens — one-time generated, stored as SHA-256 hash
model ExtensionToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique  // SHA-256(rawToken) — raw token is never stored
  name        String?            // e.g. "Chrome on MacBook"
  lastUsedAt  DateTime?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("extension_tokens")
}

// ─── Learning Platform ────────────────────────────────────────────────────────

enum CourseVisibility {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonItemType {
  VOCAB
  GRAMMAR
  TEXT
  SENTENCE
}

enum CardType {
  VOCAB_RECOGNITION
  VOCAB_PRODUCTION
  CLOZE
  GRAMMAR_READ
}

enum CardState {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

// Creator-authored course for a language
model Course {
  id          String           @id @default(cuid())
  title       String
  description String?          @db.Text
  coverImage  String?
  visibility  CourseVisibility @default(DRAFT)
  order       Int              @default(0)
  languageId  String
  authorId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  language    Language         @relation(fields: [languageId], references: [id], onDelete: Cascade)
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  units       Unit[]
  lessons     CourseLesson[]
  enrollments Enrollment[]

  @@index([languageId])
  @@index([authorId])
  @@index([languageId, visibility])
  @@map("courses")
}

// A section grouping lessons within a course (the "path" is units → lessons)
model Unit {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  order       Int      @default(0)
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@index([courseId])
  @@index([courseId, order])
  @@map("course_units")
}

model CourseLesson {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  order       Int          @default(0)
  courseId    String
  unitId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  unit        Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  items       LessonItem[]
  studyCards  StudyCard[]
  completions LessonCompletion[]

  @@index([courseId])
  @@index([courseId, order])
  @@index([unitId])
  @@map("course_lessons")
}

// Items within a lesson — each links to one content source
model LessonItem {
  id            String          @id @default(cuid())
  lessonId      String
  type          LessonItemType
  order         Int             @default(0)
  dictEntryId   String?
  grammarPageId String?
  textId        String?
  sentenceId    String?
  createdAt     DateTime        @default(now())

  lesson      CourseLesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  dictEntry   DictionaryEntry?  @relation(fields: [dictEntryId], references: [id], onDelete: Cascade)
  grammarPage GrammarPage?      @relation(fields: [grammarPageId], references: [id], onDelete: SetNull)
  text        Text?             @relation(fields: [textId], references: [id], onDelete: SetNull)
  sentence    ExampleSentence?  @relation(fields: [sentenceId], references: [id], onDelete: SetNull)

  @@index([lessonId])
  @@index([dictEntryId])
  @@index([grammarPageId])
  @@index([textId])
  @@map("lesson_items")
}

// User enrolled to learn a language
model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  languageId  String
  courseId    String?
  xp          Int       @default(0)
  streak      Int       @default(0)
  lastStudied DateTime?
  enrolledAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  language    Language    @relation(fields: [languageId], references: [id], onDelete: Cascade)
  course      Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  studyCards  StudyCard[]

  @@unique([userId, languageId])
  @@index([userId])
  @@index([languageId])
  @@map("enrollments")
}

// FSRS card — one per learnable item per enrolled user
model StudyCard {
  id            String    @id @default(cuid())
  enrollmentId  String
  lessonId      String?
  // Source — one set based on cardType
  dictEntryId   String?
  grammarPageId String?
  textId        String?
  sentenceId    String?

  cardType      CardType
  front         String    @db.Text
  back          String    @db.Text

  // FSRS scheduling state (ts-fsrs compatible)
  due           DateTime  @default(now())
  stability     Float     @default(0)
  difficulty    Float     @default(5)
  elapsedDays   Int       @default(0)
  scheduledDays Int       @default(0)
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         CardState @default(NEW)
  lastReview    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollment    Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson        CourseLesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  reviews       CardReview[]

  @@unique([enrollmentId, dictEntryId, cardType])
  @@index([enrollmentId])
  @@index([enrollmentId, due])
  @@index([enrollmentId, state])
  @@index([lessonId])
  @@map("study_cards")
}

model CardReview {
  id         String       @id @default(cuid())
  cardId     String
  rating     ReviewRating
  timeTaken  Int          // milliseconds — used for 4-second rule
  xpEarned   Int
  reviewedAt DateTime     @default(now())

  card       StudyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, reviewedAt])
  @@map("card_reviews")
}

model XPEvent {
  id         String   @id @default(cuid())
  userId     String
  languageId String
  amount     Int
  reason     String   // 'review', 'lesson_complete', 'streak_bonus', 'perfect_session'
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, languageId])
  @@index([userId, createdAt])
  @@map("xp_events")
}

// UI translations contributed by conlang creators
model ConlangTranslation {
  id          String   @id @default(cuid())
  languageId  String
  key         String   // Dot-notated key, e.g. "nav.home"
  value       String   @db.Text // Translated string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([languageId, key])
  @@index([languageId])
  @@map("conlang_translations")
}

// Tracks which lessons a user has completed and the XP/hearts earned
model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  xpEarned    Int
  heartsLeft  Int      @default(0)
  completedAt DateTime @default(now())

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_completions")
}
