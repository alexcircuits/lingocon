# Development Mode (No Auth Required)
DEV_MODE="true"

# Database (Required)
# Docker Compose default (see SETUP.md — npm run setup starts Postgres for you):
# DATABASE_URL="postgresql://langua:langua@localhost:5432/langua?schema=public"
# Or your own Postgres:
DATABASE_URL="postgresql://user:password@localhost:5432/langua?schema=public"

# Canonical public origin — used for canonical <link> tags, Open Graph URLs,
# robots.txt, sitemap.xml and JSON-LD. Localhost is fine for local dev.
#
# IMPORTANT (production): NEXT_PUBLIC_* vars are INLINED AT BUILD TIME. If you
# run `next build` with this set to localhost, every canonical/OG/sitemap URL
# ships pointing at localhost and Google will drop your pages from the index.
# On the server, set this to the real origin BEFORE building, e.g.:
#   NEXT_PUBLIC_SITE_URL="https://lingocon.com"
# Alternatively, set SITE_URL (runtime, server-only — not inlined) to override
# the origin without a rebuild. getSiteUrl() prefers SITE_URL, then
# NEXT_PUBLIC_SITE_URL, and in production refuses to emit a localhost origin.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# SITE_URL="https://lingocon.com"

# ------------------------------------------------------------------
# Production / Full Auth Configuration (Optional for Local Dev)
# ------------------------------------------------------------------

# NextAuth
# AUTH_SECRET="generate-with-openssl-rand-base64-32"
# AUTH_URL="http://localhost:3000"

# GitHub OAuth
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email (Resend) - Required for email verification and password reset
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# EMAIL_FROM="LingoCon <noreply@yourdomain.com>"