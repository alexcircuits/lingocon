# Development Mode (No Auth Required)
DEV_MODE="true"

# Database (Required)
DATABASE_URL="postgresql://user:password@localhost:5432/langua?schema=public"

# Deployment (Optional in Dev Mode)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ------------------------------------------------------------------
# Production / Full Auth Configuration (Optional for Local Dev)
# ------------------------------------------------------------------

# NextAuth
# AUTH_SECRET="generate-with-openssl-rand-base64-32"
# AUTH_URL="http://localhost:3000"

# GitHub OAuth
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email (Resend) - Required for email verification and password reset
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# EMAIL_FROM="LingoCon <noreply@yourdomain.com>"